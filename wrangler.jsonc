{
  "name": "doodlelog",
  "main": ".vercel/output/static/_worker.js/index.js",
  "compatibility_date": "2025-02-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".vercel/output/static"
  },
  "routes": [
    {
      "pattern": "doodlelog.ledpa7.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
